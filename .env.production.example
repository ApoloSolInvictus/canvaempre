VITE_FIREBASE_API_KEY=your-production-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id
VITE_GUARANTEE_DAYS=7
VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_META_PIXEL_ID=123456789012345

# Variables privadas de las funciones de Vercel. No uses el prefijo VITE_.
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
HOTMART_HOTTOK=your-hotmart-hottok

# Correos administrativos adicionales, separados por comas.
# Deben iniciar sesion con un correo verificado de Firebase/Google.
ADMIN_EMAILS=

# Alertas de errores del Webhook. Puedes usar URL de Slack/Discord o Resend.
WEBHOOK_ALERT_URL=
RESEND_API_KEY=
ALERT_EMAIL_TO=info@wstudiocr.com
ALERT_EMAIL_FROM=Canva Emprender <alertas@your-verified-domain.com>

# Opcionales: permiten rechazar eventos de otros productos u ofertas.
# Usa el valor numérico recibido en data.product.id del Webhook.
HOTMART_PRODUCT_ID=your-hotmart-product-id
HOTMART_OFFER_CODE=
