VITE_FIREBASE_API_KEY=your-production-api-key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
VITE_FIREBASE_APP_ID=your-app-id

# Variables privadas de las funciones de Vercel. No uses el prefijo VITE_.
FIREBASE_ADMIN_PROJECT_ID=your-project-id
FIREBASE_ADMIN_CLIENT_EMAIL=firebase-adminsdk@example.iam.gserviceaccount.com
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
HOTMART_HOTTOK=your-hotmart-hottok

# Opcionales: permiten rechazar eventos de otros productos u ofertas.
# Usa el valor numérico recibido en data.product.id del Webhook.
HOTMART_PRODUCT_ID=your-hotmart-product-id
HOTMART_OFFER_CODE=
