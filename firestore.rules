rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownsProfile(userId) {
      return signedIn() && request.auth.uid == userId;
    }

    match /users/{userId} {
      allow read: if ownsProfile(userId);
      allow create: if ownsProfile(userId)
        && request.resource.data.keys().hasOnly([
          'uid',
          'name',
          'email',
          'currentLevel',
          'totalProgress',
          'completedLessons',
          'favoriteCourses',
          'accessStatus',
          'syncPending',
          'createdAt',
          'updatedAt'
        ])
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.accessStatus == 'pending_payment'
        && !request.resource.data.keys().hasAny([
          'paymentProvider',
          'paymentTransaction',
          'paidAt',
          'refundedAt',
          'certificateIssuedAt',
          'certificateNumber',
          'certificateTitle'
        ]);
      allow update: if ownsProfile(userId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
          'name',
          'favoriteCourses',
          'updatedAt'
        ]);
      allow delete: if false;
    }

    match /courses/{courseId} {
      allow read, write: if false;
      allow write: if false;
    }

    match /lessons/{lessonId} {
      allow read, write: if false;
      allow write: if false;
    }

    match /certificates/{certificateId} {
      allow read, write: if false;
      allow write: if false;
    }

    match /hotmartEntitlements/{documentId} {
      allow read, write: if false;
    }

    match /hotmartWebhookEvents/{documentId} {
      allow read, write: if false;
    }
  }
}
